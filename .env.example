# Twilio Credentials (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Config
PORT=3000
BASE_URL=https://your-domain.ngrok-free.app

# Receptionist Config
BUSINESS_NAME=Your Business Name
BUSINESS_HOURS=9AM - 5PM, Monday to Friday
RECEPTIONIST_GREETING=Hello! Thank you for calling. How can I help you today?
